{
  "manifest_version": 3,
  "name": "WEBGuard",
  "version": "1.0",

  "description": "AI-Powered Phishing Detection Extension",

  "background": {
    "service_worker": "background.js"
  },

  "permissions": [
    "tabs",
    "activeTab",
    "scripting",
    "notifications"
  ],

  "host_permissions": [
    "http://127.0.0.1:8000/*",
    "<all_urls>"
  ],
  
  "action": {
    "default_popup": "popup.html"
  },

  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"]
    }
  ] 
}